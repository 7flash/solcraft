# Stage 29–40 clean ECS release candidate
SOLCRAFT_BACKEND_MODE=ecs
SOLCRAFT_ENABLE_LEGACY_BACKEND=0
SOLCRAFT_STRICT_CLEAN_RELEASE=1
SOLCRAFT_DB=solcraft.clean.db

# Removed legacy systems: keep all disabled.
SOLCRAFT_ENABLE_BOMBS=0
SOLCRAFT_ENABLE_TERRITORY_COINS=0
SOLCRAFT_ENABLE_PASSIVE_PRODUCTION=0
SOLCRAFT_ENABLE_DEV_COMMANDS=0

# Production-style bank/audit tables.
SOLCRAFT_BANK_TABLES=1
SOLCRAFT_MEASURE_RING_MAX=2500

# Required before staging/prod admin endpoints are useful.
SOLCRAFT_ADMIN_KEY=change-me
SOLCRAFT_DEPLOY_ADMIN_KEY=change-me

# Optional external checks.
SOLCRAFT_BASE_URL=http://localhost:3000
