{
  "name": "sky-kingdoms-tradjs-bun",
  "version": "25.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "web": "bun run server.ts",
    "game": "bun run game-server.ts",
    "check": "bun run scripts/check.ts",
    "clean": "bun -e \"import { rmSync } from 'fs'; for (const p of ['node_modules','bun.lock','bun.lockb']) { try { rmSync(p,{recursive:true,force:true}); } catch {} }\"",
    "test:ecs": "bun test server/ecs/*.test.ts",
    "test:ecs:watch": "bun test --watch server/ecs/*.test.ts"
  },
  "dependencies": {
    "measure-fn": "4.0.4",
    "sqlite-zod-orm": "^3.27.0",
    "three": "^0.171.0",
    "tradjs": "^4.1.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.2"
  }
}
